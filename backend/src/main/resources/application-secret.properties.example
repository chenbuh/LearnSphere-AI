# 机密配置示例文件
# 使用说明：
# 1. 复制本文件为 application-secret.properties
# 2. 将真实账号、密码、密钥填入复制后的文件
# 3. application-secret.properties 已在 .gitignore 中忽略，不会提交到仓库
# 4. 如果启用了 Jasypt 加密，请同时提供环境变量 JASYPT_PASSWORD

# AI 配置
# DashScope / 百炼 API Key
ai.api-key=your-ai-api-key
# 可选：覆盖默认模型
# ai.model=qwen-turbo
# 可选：覆盖兼容接口地址
# ai.api-url=https://dashscope.aliyuncs.com/compatible-mode/v1/chat/completions

# 数据库配置
spring.datasource.username=your-db-username
spring.datasource.password=your-db-password

# 可选：Redis 认证
# spring.redis.password=your-redis-password
